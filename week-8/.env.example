PORT=5001
NODE_ENV=development
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/leadgen-api

# Auth
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRE=7d

# Email (choose one)
# Option A: SMTP (Mailtrap for dev, SendGrid/SES for prod)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_mailtrap_user
EMAIL_PASS=your_mailtrap_pass
EMAIL_FROM="Lead Gen API <noreply@yourdomain.com>"

# Option B: Gmail
# GMAIL_USER=yourapp@gmail.com
# GMAIL_APP_PASSWORD=your_16_char_app_password

# Lead alert recipient (business owner email)
ALERT_EMAIL=business@example.com
